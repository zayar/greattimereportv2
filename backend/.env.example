PORT=5050
CORS_ORIGIN=http://localhost:5174,https://gtreport-v2.web.app,https://gtreport-v2.firebaseapp.com
APICORE_GRAPHQL_URL=https://greattime-api-core-hs6rtohe3q-uc.a.run.app/apicore
APICORE_SERVICE_USERNAME=
APICORE_SERVICE_PASSWORD=
AI_PROVIDER=gemini
AI_DEFAULT_LANGUAGE=my-MM
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# Used only for per-request cost estimates in Agent Hub monitoring. Update when provider pricing changes.
GEMINI_INPUT_COST_PER_MILLION_USD=1.5
GEMINI_OUTPUT_COST_PER_MILLION_USD=9
# Used only for Queen Consultant knowledge-authoring suggestions. Never expose this key to the frontend.
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_CONSULTANT_KNOWLEDGE_MODEL=gpt-5.6-sol
OPENAI_CONSULTANT_KNOWLEDGE_REASONING_EFFORT=medium
OPENAI_CONSULTANT_KNOWLEDGE_TIMEOUT_MS=90000
OPENAI_CONSULTANT_KNOWLEDGE_MAX_OUTPUT_TOKENS=8000
APP_BASE_URL=
DEFAULT_TIMEZONE=Asia/Yangon
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_WEB_API_KEY=
BQ_PROJECT_ID=pitistartup
BQ_DATASET=great_time
BQ_LOCATION=US
BQ_MAIN_DATA_VIEW=MainDataView
BQ_MAIN_PAYMENT_VIEW=MainPaymentView
# In-memory BigQuery result cache for successful SELECT-style analytics queries.
BQ_QUERY_CACHE_ENABLED=true
# Default per-query cache TTL in milliseconds when a call does not override ttlMs.
BQ_QUERY_DEFAULT_TTL_MS=60000
# Maximum in-memory BigQuery cache entries before oldest-entry eviction.
BQ_QUERY_CACHE_MAX_ENTRIES=500
# Log bigquery_query_slow when query latency is at or above this threshold.
BQ_QUERY_SLOW_MS=2500
# Global report BigQuery timeout guard in milliseconds. This does not cancel the backend BigQuery job.
BQ_QUERY_TIMEOUT_MS=30000
# Optional BigQuery maximum bytes billed per job. Use 0 to leave unset.
BQ_MAX_BYTES_BILLED=0
GT_GROWTH_AI_DEFAULT_ENABLED=false
GT_GROWTH_AI_ENABLED_CLINIC_IDS=
GT_GROWTH_AI_FEATURE_STORE_ENABLED=true
GT_GROWTH_AI_ADMIN_EMAILS=zayar@datafocus.cloud
AI_AGENT_MONITORING_ADMIN_EMAILS=zayar@datafocus.cloud
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_LINK_CODE_TTL_MINUTES=15
TELEGRAM_REPORT_DEFAULT_TIME=08:00
TELEGRAM_SCHEDULER_ENABLED=true
TELEGRAM_SCHEDULER_INTERVAL_MS=60000
TELEGRAM_SCHEDULER_SECRET=
TELEGRAM_WEBHOOK_ENABLED=true
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_POLLING_ENABLED=false
TELEGRAM_POLLING_INTERVAL_MS=5000
SHOW_FULL_CUSTOMER_PHONE=false
MASK_PHONE_IN_GROUP_CHAT=true
APPOINTMENT_BUTTON_PHONE_SUFFIX_DIGITS=3
MAX_APPOINTMENT_BUTTONS_PER_PAGE=8
AGENT_MEMORY_V2_ENABLED=false
AGENT_LEARNING_ENABLED=false
# Keep user-facing Agent Hub business-source execution read-only.
AGENT_HUB_READ_ONLY_MODE=true
# Short BigQuery timeout guard for Agent Hub request-path tools.
AGENT_BIGQUERY_TIMEOUT_MS=8000
# Maximum Agent Hub tools to run at the same time for one request.
AGENT_TOOL_MAX_CONCURRENCY=3
# Use Gemini structured output to understand mixed-language intent and entities.
# Invalid, low-confidence, unavailable, or timed-out model output automatically uses the deterministic planner.
AGENT_SEMANTIC_PLANNER_ENABLED=true
AGENT_SEMANTIC_PLANNER_MODEL=gemini-3.5-flash
AGENT_SEMANTIC_PLANNER_TIMEOUT_MS=3000
AGENT_SEMANTIC_PLANNER_MAX_OUTPUT_TOKENS=1200
AGENT_SEMANTIC_PLANNER_MIN_CONFIDENCE=0.65
# Reject narrative wording that introduces numbers or core fields not present in typed tool evidence.
AGENT_FACT_VERIFICATION_ENABLED=true
# Disable to always return deterministic Agent Hub responses without AI narrative enhancement.
AGENT_NARRATIVE_ENABLED=true
# When enabled, AI narrative enhancement is bounded by AGENT_NARRATIVE_TIMEOUT_MS.
AGENT_FAST_MODE_ENABLED=true
# Maximum time to wait for Agent Hub narrative AI before returning the deterministic response.
AGENT_NARRATIVE_TIMEOUT_MS=1500
# Enable Agent Hub Firestore fact snapshot fast paths before BigQuery/APICORE fallback.
AGENT_SNAPSHOT_CACHE_ENABLED=true
# Maximum age for general source-backed snapshots used in Agent Hub, in minutes.
AGENT_SNAPSHOT_MAX_AGE_MINUTES=1440
# Maximum age for operational appointment snapshots used for live-count fast paths, in minutes.
AGENT_OPERATIONAL_SNAPSHOT_MAX_AGE_MINUTES=20
# Enable completed historical day snapshots for daily finance/business answers.
AGENT_COMPLETED_DAY_SNAPSHOT_ENABLED=true
# Enable routing explicit owner daily brief questions to the snapshot-backed fast tool.
AGENT_OWNER_DAILY_BRIEF_ENABLED=true
AGENT_LEARNING_SCHEDULER_SECRET=
AGENT_LEARNING_DEFAULT_LOOKBACK_DAYS=365
AGENT_STALE_THRESHOLD_HOURS=24
AGENT_LEARNING_SCHEDULER_JOB_NAME=gt-v2report-agent-learning-scheduler
AGENT_LEARNING_SCHEDULER_CRON=*/15 * * * *
AGENT_LEARNING_SCHEDULER_TIME_ZONE=Asia/Yangon
AGENT_OPERATIONAL_SNAPSHOT_INTERVAL_MINUTES=15
AGENT_LEARNING_MAX_CLINIC_CONCURRENCY=3
